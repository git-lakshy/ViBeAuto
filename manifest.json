{
  "manifest_version": 3,
  "name": "ViBe Auto",
  "version": "1.0",
  "description": "Automates video waiting and solves multiple-choice quizzes on ViBe using Gemini and Groq AI.",
  "author": "frieren(?)",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://vibe.vicharanashala.ai/*",
    "https://generativelanguage.googleapis.com/*",
    "https://*.youtube.com/embed/*",
    "https://*.youtube-nocookie.com/embed/*",
    "https://*.vimeo.com/video/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://vibe.vicharanashala.ai/*",
        "https://*.youtube.com/embed/*",
        "https://*.youtube-nocookie.com/embed/*",
        "https://*.vimeo.com/video/*"
      ],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["camera_patch.js", "default.jpg"],
      "matches": [
        "https://vibe.vicharanashala.ai/*",
        "https://*.youtube.com/*",
        "https://*.youtube-nocookie.com/*",
        "https://*.vimeo.com/*"
      ]
    }
  ]
}
